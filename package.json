{
  "name": "maybyte_by_adnan",
  "version": "1.5.4",
  "description": "Maybyte is Dashboard Monitoring Server Based on Website and crafted by Adnan",
  "main": "index.js",
  "scripts": {
    "tail": "npx tailwindcss -i ./src/input.css -o ./static/css/output.css --watch",
    "flask": "./venv/bin/python app.py",
    "dev": "concurrently \"npm run tail\" \"npm run flask\""
  },
  "keywords": [
    "flask",
    "dashboard",
    "monitoring",
    "system",
    "tailwindcss"
  ],
  "author": "Adnan Slamet Wibowo",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
